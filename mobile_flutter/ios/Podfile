platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    # Disable per-framework code signing for pods — fixes com.apple.provenance
    # codesign failures on macOS Sequoia (15+). The host app re-signs everything.
    target.build_configurations.each do |config|
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
      config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
      config.build_settings['EXPANDED_CODE_SIGN_IDENTITY'] = ''
    end
  end

  # Inject a Run Script phase into the Runner target that strips
  # com.apple.provenance from all embedded frameworks BEFORE codesigning.
  # Required on macOS Sequoia (15+) where the OS adds this attribute on copy.
  runner_project_path = File.expand_path('../Runner.xcodeproj', __FILE__)
  runner_project = Xcodeproj::Project.open(runner_project_path)
  runner_project.targets.each do |target|
    next unless target.name == 'Runner'

    # Add --no-strict to codesign to bypass com.apple.provenance check on macOS Sequoia
    target.build_configurations.each do |config|
      config.build_settings['OTHER_CODE_SIGN_FLAGS'] = '--no-strict'
    end

    next if target.build_phases.any? { |p| p.respond_to?(:name) && p.name == 'Strip com.apple.provenance' }

    phase = target.new_shell_script_build_phase('Strip com.apple.provenance')
    phase.shell_script = <<~'SHELL'
      # Remove com.apple.provenance added by macOS Sequoia during file copy.
      # This must run AFTER Embed Frameworks and BEFORE final code signing.
      APP="${BUILT_PRODUCTS_DIR}/${WRAPPER_NAME}"
      dot_clean -m "$APP" 2>/dev/null || true
      find "$APP" -print0 | xargs -0 xattr -d com.apple.provenance 2>/dev/null || true
      find "$APP" -print0 | xargs -0 xattr -d com.apple.FinderInfo 2>/dev/null || true
    SHELL

    # Move to just after the last CopyFiles (Embed Frameworks) phase
    embed_idx = target.build_phases.rindex { |p| p.is_a?(Xcodeproj::Project::Object::PBXCopyFilesBuildPhase) }
    if embed_idx
      target.build_phases.delete(phase)
      target.build_phases.insert(embed_idx + 1, phase)
    end
  end
  runner_project.save
end
